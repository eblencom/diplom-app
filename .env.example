DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diplom_db
SESSION_SECRET=change_me_to_a_random_long_string
PYTHON_BIN=python
NEWS_PARSER_LOG_PATH=./news_parser_log.txt
# Если ru.investing.com отвечает 403 на HTML: HTTPS_PROXY=... или домашний IP.
# Общерыночные RSS при отсутствии совпадения по эмитенту включены по умолчанию; отключить: NEWS_PARSER_MACRO_RSS=0
NEWS_PARSER_MACRO_RSS=

# Telegram: бот минутной рассылки цен (scripts/tg_price_bot.cjs)
TELEGRAM_BOT_TOKEN=
# Имя бота без @ — для ссылки t.me/... на странице профиля
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
